<UserControl x:Class="WPF.UCL.UserControls.Fields.InputTextFieldWithButtonUc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF.UCL.UserControls.Fields"
             mc:Ignorable="d" 
             d:DesignWidth="450" MinWidth="300" 
             d:DesignHeight="50" MinHeight="50"
             Background="Transparent">
    
    <Border Background="Bisque" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="100" /> <!-- Для названия -->
                <ColumnDefinition Width="*" />   <!-- Для поля ввода -->
                <ColumnDefinition Width="40" />  <!-- Для доп. кнопки -->
                <ColumnDefinition Width="40" />  <!-- Для кнопки очистки -->
            </Grid.ColumnDefinitions>
            
            <!-- Название поля -->
            <TextBlock Grid.Column="0" x:Name="InputNameTextBlock"
                       Text="{Binding FieldName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       Margin="10,0,5,0"
                       FontWeight="Bold" />

            <!-- Поле ввода -->
            <TextBox Grid.Column="1" x:Name="InputTextBox"
                     Text="{Binding InputText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="5,0" />

            <!-- Дополнительная кнопка -->
            <Button Grid.Column="2" 
                    Background="LightBlue" 
                    Content="{Binding ButtonContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Command="{Binding ButtonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding ButtonCommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="{Binding ButtonToolTip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Margin="2" />

            <!-- Кнопка очистки -->
            <Button Grid.Column="3" 
                    Background="Tan" 
                    Content="❌" 
                    Click="ClearButton_OnClick"
                    ToolTip="Очистить поле"
                    Margin="2" />

        </Grid>
    </Border>
</UserControl>
