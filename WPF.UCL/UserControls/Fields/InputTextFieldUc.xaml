<UserControl x:Class="WPF.UCL.UserControls.Fields.InputTextFieldUc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF.UCL.UserControls.Fields"
             mc:Ignorable="d" 
             d:DesignWidth="450" MinWidth="300" 
             d:DesignHeight="20" MinHeight="15"
             Background="Transparent">
    
    <Border Background="Bisque" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" /> <!-- Название поля -->
                <ColumnDefinition Width="*" /> <!-- Поле ввода -->
                <ColumnDefinition Width="50" />  <!-- Кнопка очистки -->
            </Grid.ColumnDefinitions>
            
            <!-- Название поля -->
            <TextBlock Grid.Column="0" x:Name="InputNameTextBlock"
                       Text="{Binding FieldName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       Margin="10,0,5,0"
                       FontWeight="Bold" />

            <!-- Поле ввода -->
            <TextBox Grid.Column="1" x:Name="InputTextBox"
                     Text="{Binding InputText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2" 
                    Background="Tan" Content="❌" 
                    Click="ClearButton_OnClick" />

        </Grid>
    </Border>
</UserControl>
