<UserControl x:Class="WPF.UCL.LinkControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF.UCL"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <TextBlock x:Name="LinkTextBlock"
               Text="{Binding LinkUrl, ElementName=root}"
               Foreground="Blue"
               TextDecorations="Underline"
               Cursor="Hand"
               ToolTip="Щелкните для открытия ссылки"
               MouseLeftButtonDown="LinkTextBlock_MouseLeftButtonDown"/>
</UserControl>
