<UserControl x:Class="WPF.UCL.LinkFieldControl"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="25" d:DesignWidth="300">
    <Grid>
        <Grid.Background>LightBlue</Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <!-- Название поля -->
        <TextBlock Grid.Column="0"
                   Text="{Binding FieldName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="Black"  
                   Background="LightGray"  
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontWeight="SemiBold"/>
        
        <!-- Ссылка -->
        <TextBlock Grid.Column="1"
                   Text="{Binding LinkUrl, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="Blue"
                   Background="Bisque"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   VerticalAlignment="Center"
                   ToolTip="Щелкните для открытия ссылки"
                   MouseLeftButtonDown="LinkTextBlock_MouseLeftButtonDown"/>
        
        <!-- Кнопка установки ссылки -->
        <Button Grid.Column="2"
                Content="..."
                Width="25"
                Height="25"
                Margin="5,0,0,0"
                Command="{Binding SetLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ToolTip="Установить ссылку"/>
    </Grid>
</UserControl>