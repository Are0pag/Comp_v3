<UserControl x:Class="WPF.UCL.ImageFieldControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF.UCL"
             mc:Ignorable="d"
             x:Name="root"
             d:DesignHeight="300" d:DesignWidth="300">
    
    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        
        <!-- Placeholder изображение через GeometryDrawing -->
        <DrawingImage x:Key="NoImagePlaceholder">
            <DrawingImage.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,100,100"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Brush>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Grid Background="LightGray">
                                    <TextBlock Text="No Image" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               Foreground="Gray"/>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Pen>
                        <Pen Brush="DarkGray" Thickness="1"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Область изображения -->
        <Border Grid.Row="0" 
                BorderBrush="LightGray" 
                BorderThickness="1" 
                Background="WhiteSmoke"
                CornerRadius="4"
                Margin="5">
            
            <Image x:Name="PreviewImage"
                   Source="{Binding ImageSource, ElementName=root}"
                   ToolTip="{Binding ImageToolTip, ElementName=root}"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MaxWidth="360"
                   MaxHeight="240">
                
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Source" Value="{StaticResource NoImagePlaceholder}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ImageSource, ElementName=root}" Value="{x:Null}">
                                <Setter Property="Source" Value="{StaticResource NoImagePlaceholder}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Border>
        
        <!-- Панель кнопок -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="5">
            
            <Button Content="{Binding Button1Text, ElementName=root}"
                    Command="{Binding Button1Command, ElementName=root}"
                    Style="{StaticResource ActionButtonStyle}"/>
            
            <Button Content="{Binding Button2Text, ElementName=root}"
                    Command="{Binding Button2Command, ElementName=root}"
                    Style="{StaticResource ActionButtonStyle}"/>
            
            <Button Content="{Binding Button3Text, ElementName=root}"
                    Command="{Binding Button3Command, ElementName=root}"
                    Style="{StaticResource ActionButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>