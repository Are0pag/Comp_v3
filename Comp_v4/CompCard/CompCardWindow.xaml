<Window x:Class="Comp_v4.CompCard.CompCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.CompCard"
        xmlns:fields="clr-namespace:WPF.UCL.UserControls.Fields;assembly=WPF.UCL"
        mc:Ignorable="d"
        Title="CompCardWindow" Height="450" Width="800">
    
    <StackPanel>
        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5" FontWeight="Bold" />
        <fields:InputTextFieldWithButtonUc 
            InputText="{Binding UserName, Mode=TwoWay}"
            ButtonContent="🎲"
            ButtonCommand="{Binding GenerateUserNameCommand}"
            ButtonToolTip="Сгенерировать имя"
            Margin="0,0,0,15" />
    </StackPanel>
</Window>
