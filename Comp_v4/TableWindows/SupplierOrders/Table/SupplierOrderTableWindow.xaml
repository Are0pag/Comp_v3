<Window x:Class="Comp_v4.TableWindows.SupplierOrders.Table.SupplierOrderTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.SupplierOrders.Table"
        xmlns:form="clr-namespace:Comp_v4.TableWindows.SupplierOrders.Form;assembly=Utils"
        mc:Ignorable="d"
        Title="Заказы поставщикам" Height="450" Width="1600"
        PreviewKeyDown="SupplierOrderTableWindow_OnPreviewKeyDown"
        PreviewMouseDown="SupplierOrderTableWindow_OnPreviewMouseDown">
    
    <Window.Resources>
        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <form:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Height="40">
            <Button x:Name="AddButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="EditButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="OpenOrderPositionsButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="OpenPaymentOrdersButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="DeleteButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            
            <Grid x:Name="FilterGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" x:Name="FilterTextBox"
                         Text="{Binding FilterString, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Width="200" Height="25" Margin="20,0,0,0" 
                         VerticalContentAlignment="Center"/>

                <CheckBox Grid.Row="1" x:Name="IgnoreCaseCheckBox" 
                          Content="Учёт регистра" 
                          IsChecked="{Binding IgnoreCase, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          FontSize="10"
                          HorizontalAlignment="Left"
                          Margin="20,0,0,0"/>
            </Grid>
        </StackPanel>
        
        <DataGrid Grid.Row="1" 
                  x:Name="DataGrid" 
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  Margin="10" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  MouseDoubleClick="DataGrid_OnMouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер заказа" Binding="{Binding PurchaseOrderNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Counterparty.ShortName}" Width="Auto"/>
                <DataGridTextColumn 
                    Header="НДС" 
                    Binding="{Binding VatStatusEnumValue, Converter={StaticResource EnumDescriptionConverter}}" 
                    Width="Auto"/>
                <DataGridTextColumn 
                    Header="Состояние" 
                    Binding="{Binding OrderStatusEnumValue, Converter={StaticResource EnumDescriptionConverter}}" 
                    Width="Auto"/>
                <DataGridTextColumn Header="Номер договора" Binding="{Binding OrderNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Номер счёта" Binding="{Binding InvoiceNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate}" Width="Auto"/>
                <DataGridTextColumn Header="Дата поставки" Binding="{Binding DeliveryDate}" Width="Auto"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="*"/>
                
                <DataGridTextColumn Header="% оплаты" Binding="{Binding PercentageOfTotalPayment}" Width="*"/>
                <DataGridTextColumn 
                    Header="Статус оплаты" 
                    Binding="{Binding PaymentStatusEnumValue, Converter={StaticResource EnumDescriptionConverter}}" 
                    Width="*"/>
                
                <DataGridTextColumn Header="Кол-во заказано" Binding="{Binding OrderedUnitsAmount}" Width="*"/>
                <DataGridTextColumn Header="Кол-во получено" Binding="{Binding ReceivedUnitsAmount}" Width="*"/>
                <DataGridTextColumn 
                    Header="Статус получения" 
                    Binding="{Binding ReceiveStatusEnumValue, Converter={StaticResource EnumDescriptionConverter}}" 
                    Width="*"/>
                
                <DataGridTextColumn Header="Сумма заказа" Binding="{Binding TotalOrderCost}" Width="*"/>
                <DataGridTextColumn Header="Сумма оплаты" Binding="{Binding TotalPayment}" Width="*"/>
                <DataGridTextColumn Header="Сумма НДС" Binding="{Binding TotalVatAmount}" Width="*"/>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
