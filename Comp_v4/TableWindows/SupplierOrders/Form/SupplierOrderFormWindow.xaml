<Window x:Class="Comp_v4.TableWindows.SupplierOrders.Form.SupplierOrderFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.SupplierOrders.Form"
        xmlns:ucl="clr-namespace:WPF.UCL;assembly=WPF.UCL"
        mc:Ignorable="d"
        Title="Заказ поставщику" Height="450" Width="800">
    
    <Window.Resources>
        <local:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Номер заказа:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBox x:Name="PurchaseOrderNumberTextBox"
                         Text="{Binding PurchaseOrderNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Width="500" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Button x:Name="PurchaseOrderNumberClearButton"
                        Command="{Binding ClickCommand}"
                        Content="✖"
                        Width="30" Margin="0,0,10,0" ToolTip="Открыть" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Дата заказа:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <DatePicker Name="OrderDateDatePicker"
                            SelectedDate="{Binding OrderDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                            />
                <Button x:Name="OrderDateButton"
                        Command="{Binding ClickCommand}"
                        Content="Установить сегодняшнюю" Width="150" ToolTip="Очистить" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Поставщик:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock 
                    Text="{Binding Counterparty.ShortName, UpdateSourceTrigger=PropertyChanged}"
                    Width="Auto" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Button x:Name="CounterpartySelectButton"
                        Command="{Binding ClickCommand}"
                        Content="🔍" 
                        Width="30" Margin="0,0,10,0" ToolTip="Открыть" VerticalAlignment="Center"/>
                <Button x:Name="CounterpartyClearButton"
                        Command="{Binding ClickCommand}"
                        Content="✖" 
                        Width="30" ToolTip="Очистить" VerticalAlignment="Center"/>
            </StackPanel>
            
            <ucl:LinkFieldControl 
                x:Name="ContractLinkFieldControl"
                FieldName="{Binding FieldTitle}"
                LinkUrl="{Binding Url}"
                SetLinkCommand="{Binding SetLinkCommand}"
                />
            
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Номер счёта:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    Width="500" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Button Content="✖" Width="30" ToolTip="Очистить" VerticalAlignment="Center"/>
            </StackPanel>
            
            
            <ucl:LinkFieldControl 
                x:Name="InvoiceFilePathLinkFieldControl"
                FieldName="{Binding FieldTitle}"
                LinkUrl="{Binding Url}"
                SetLinkCommand="{Binding SetLinkCommand}"
            />
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Дата поставки:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <DatePicker Name="DeliveryDateDatePicker"
                            SelectedDate="{Binding DeliveryDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                />
                <Button x:Name="DeliveryDateButton"
                        Command="{Binding ClickCommand}"
                        Content="Установить сегодняшнюю" Width="150" ToolTip="Очистить" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Статус НДС:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="VatStatusComboBox" 
                          ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding SelectedValue}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ., Converter={StaticResource EnumDescriptionConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Статус НДС:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="OrderStatusComboBox" 
                          ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding SelectedValue}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ., Converter={StaticResource EnumDescriptionConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Примечание:" Width="150" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    Width="500" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Button Content="✖" Width="30" ToolTip="Очистить" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="SaveButton" 
                    Content="{Binding Label}"
                    Command="{Binding ClickCommand}"
                    Padding="10,5"  
                    MinWidth="80" MinHeight="25"
                    />
        </StackPanel>
    </Grid>
</Window>