<Window x:Class="Comp_v4.TableWindows.Counterparties.Table.CounterpartyTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.Counterparties.Table"
        mc:Ignorable="d"
        Title="Контрагенты" Height="600" Width="1000">
    
    <Window.Resources>
        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Height="40">
            <Button x:Name="AddButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="EditButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="DeleteButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            
            <Grid x:Name="FilterGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" x:Name="FilterTextBox"
                         Text="{Binding FilterString, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Width="200" Height="25" Margin="20,0,0,0" 
                         VerticalContentAlignment="Center"/>

                <CheckBox Grid.Row="1" x:Name="IgnoreCaseCheckBox" 
                          Content="Учёт регистра" 
                          IsChecked="{Binding IgnoreCase, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          FontSize="10"
                          HorizontalAlignment="Left"
                          Margin="20,0,0,0"/>
            </Grid>


            
            <ComboBox Width="150" Height="30" Margin="10,0,0,0"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Supplier"/>
                <ComboBoxItem Content="Client"/>
            </ComboBox>
        </StackPanel>
        
        <!-- Таблица контрагентов -->
        <DataGrid Grid.Row="1" 
                  x:Name="MainDataGrid" 
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  Margin="10" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Краткое наименование" Binding="{Binding ShortName}" Width="120"/>
                <DataGridTextColumn Header="Полное наименование" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Город" Binding="{Binding CityName}" Width="100"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="120"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Tin}" Width="100"/>
                <DataGridTextColumn Header="URL" Binding="{Binding Website}" Width="120"/>
                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="120"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="100"/>
                <DataGridTextColumn Header="Тип контрагента" Binding="{Binding CounterpartyTypeName}" Width="120"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>