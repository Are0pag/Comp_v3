<Window x:Class="Comp_v4.TableWindows.Counterparties.CounterpartyFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.Counterparties"
        xmlns:form="clr-namespace:Comp_v4.TableWindows.SupplierOrders.Form;assembly=Utils"
        mc:Ignorable="d"
        Title="Добавление контрагента" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <form:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Карточка контрагента" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Вкладки -->
        <TabControl Grid.Row="1">
            <!-- Вкладка Реквизиты -->
            <TabItem Header="Реквизиты">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Тип контрагента -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип контрагента:"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                  x:Name="CounterpartyTypeComboBox" 
                                  ItemsSource="{Binding CounterpartyTypes}"
                                  SelectedItem="{Binding CounterpartyType}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ., Converter={StaticResource EnumDescriptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Краткое наименование -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Краткое наименование:*"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding ShortName}"/>

                        <!-- Полное наименование -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Полное наименование:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                 Text="{Binding FullName}"/>

                        <!-- Город -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Город:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" 
                                 Text="{Binding CityName}"/>

                        <!-- Адрес -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Адрес:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" 
                                 Text="{Binding Address}" 
                                 AcceptsReturn="True" 
                                 Height="60" 
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"/>

                        <!-- ИНН -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="ИНН:"/>
                        <TextBox Grid.Row="5" Grid.Column="1" 
                                 Text="{Binding Tin}"/>

                        <!-- КПП -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="КПП:"/>
                        <TextBox Grid.Row="6" Grid.Column="1" 
                                 Text="{Binding ReasonCode}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Банковские реквизиты -->
            <TabItem Header="Банковские реквизиты">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Наименование банка -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование банка:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 Text="{Binding BankName}"/>

                        <!-- Расчетный счет -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Расчетный счет:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding SettlementAccount}"/>

                        <!-- Минимальная сумма заказа -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Мин. сумма заказа:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                 Text="{Binding MinimumOrderAmount}"/>

                        <!-- Плательщик НДС -->
                        <CheckBox Grid.Row="3" Grid.Column="1" 
                                  Content="Плательщик НДС"
                                  IsChecked="{Binding IsVatTaxpayer}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка Контакты -->
            <TabItem Header="Контакты">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Телефон -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Телефон:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 Text="{Binding PhoneNumber}"/>

                        <!-- Email -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding Email}"/>

                        <!-- Веб-сайт -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Веб-сайт:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                 Text="{Binding Website}"/>

                        <!-- Логин сайта -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин сайта:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" 
                                 Text="{Binding WebsiteLogin}"/>

                        <!-- Пароль сайта -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль сайта:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" 
                                 Text="{Binding WebsitePassword}"/>

                        <!-- Комментарий -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Комментарий:"/>
                        <TextBox Grid.Row="5" Grid.Column="1" 
                                 Text="{Binding Comment}" 
                                 AcceptsReturn="True" 
                                 Height="80" 
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Width="80" Height="25" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Отмена" Width="80" Height="25" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
