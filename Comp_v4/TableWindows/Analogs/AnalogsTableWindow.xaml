<Window x:Class="Comp_v4.TableWindows.Analogs.AnalogsTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.Analogs"
        mc:Ignorable="d"
        Title="Взаимозаменяемость компонентов" Height="450" Width="800">
    
    <Window.Resources>
        <local:BoolToTextConverter x:Key="BoolToTextConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <DataGrid ItemsSource="{Binding Items}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  SelectionMode="Single" 
                  x:Name="MainDataGrid" 
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="False"
                  SelectedItem="{Binding SelectedItem}"
                  Grid.Row="0"
                  MouseDoubleClick="MainDataGrid_OnMouseDoubleClick">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Основной компонент" IsReadOnly="True" Binding="{Binding SourceComponent.Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Аналог" IsReadOnly="True" Binding="{Binding RelatedComponent.Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridCheckBoxColumn Header="Всё кол-во" IsReadOnly="True" Binding="{Binding IsAllCount, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
            
        </DataGrid>
        
        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="AddAnalogButton" 
                    Content="{Binding Label}" 
                    Command="{Binding AddCommand}" 
                    Margin="5,0" 
                    Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>