<windows:TableWindowBase x:Class="Comp_v4.TableWindows.OrderPositions.Table.OrderPositionsTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.TableWindows.OrderPositions.Table"
        xmlns:form="clr-namespace:Comp_v4.TableWindows.OrderPositions.Form"
        xmlns:form1="clr-namespace:Comp_v4.TableWindows.SupplierOrders.Form;assembly=Utils"
        xmlns:windows="clr-namespace:Utils.WPF.Windows;assembly=Utils"
        mc:Ignorable="d"
        Title="Состав заказа" Height="900" Width="1200"
        PreviewKeyDown="SupplierOrderTableWindow_OnPreviewKeyDown"
        PreviewMouseDown="SupplierOrderTableWindow_OnPreviewMouseDown">
    
    <windows:TableWindowBase.Resources>
        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <form1:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </windows:TableWindowBase.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Height="40">
            <Button x:Name="AddButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="EditButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            <Button x:Name="DeleteButton" 
                    Content="{Binding Label}" 
                    Command="{Binding ClickCommand}" 
                    Style="{StaticResource ToolBarButtonStyle}"/>
            
            <Grid x:Name="FilterGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" x:Name="FilterTextBox"
                         Text="{Binding FilterString, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Width="200" Height="25" Margin="20,0,0,0" 
                         VerticalContentAlignment="Center"/>

                <CheckBox Grid.Row="1" x:Name="IgnoreCaseCheckBox" 
                          Content="Учёт регистра" 
                          IsChecked="{Binding IgnoreCase, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          FontSize="10"
                          HorizontalAlignment="Left"
                          Margin="20,0,0,0"/>
            </Grid>
        </StackPanel>
        
        <DataGrid Grid.Row="1" 
                  x:Name="DataGrid" 
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  Margin="10" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  MouseDoubleClick="DataGrid_OnMouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование позиции" Binding="{Binding Position.Name}" Width="Auto"/>
                <DataGridTextColumn Header="Номенклатурный номер" Binding="{Binding Position.NomenclatureNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Номер по каталогу" Binding="{Binding Position.CatalogNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Типоразмер" Binding="{Binding Position.TypeSize.Designation}" Width="Auto"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Position.Manufacturer.Designation}" Width="Auto"/>
                <DataGridTextColumn Header="Ед. изм-я" Binding="{Binding Position.ConditionalDesignation.Designation}" Width="Auto"/>
                
                <DataGridTextColumn Header="Кол-во заказано" Binding="{Binding OrderQuantity}" Width="Auto"/>
                <DataGridTextColumn Header="Кол-во получено" Binding="{Binding ReceivedQuantity}" Width="Auto"/>
                <DataGridTemplateColumn Header="Статус получения" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ReceiveStatusEnumValue, Converter={StaticResource EnumDescriptionConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Цена за ед." Binding="{Binding UnitPrice}" Width="Auto"/>
                <DataGridTextColumn Header="Сумма стоимости" Binding="{Binding TotalCost}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</windows:TableWindowBase>
