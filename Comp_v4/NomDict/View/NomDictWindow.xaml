<Window x:Class="Comp_v4.NomDict.View.NomDictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v4.NomDict.View"
        mc:Ignorable="d"
        Title="Номенклатурный словарь" Height="750" Width="1500"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_OnPreviewMouseDown">
     
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>  <!-- Часть A: 30% ширины -->
            <ColumnDefinition Width="7*"/>  <!-- Часть B: 70% ширины -->
        </Grid.ColumnDefinitions>
        
        <!-- ===== ЧАСТЬ A (30% ширины) ===== -->
        <Grid Grid.Column="0" Name="PartA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Панель инструментов A (фиксированная) -->
                <RowDefinition Height="*"/>     <!-- Основное содержимое A (расширяемое) -->
            </Grid.RowDefinitions>
            
            <!-- Панель инструментов части A -->
            <Border Grid.Row="0" Name="PartAToolbar" Background="LightGray" Height="40">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                    <Button Content="+" Margin="2" Padding="10,2"
                            x:Name="TreeView_Button_Add"
                            Command="{Binding ClickCommand}"/>
                    <Button Content="Новое имя" Margin="2" Padding="10,2"
                            x:Name="TreeView_Button_UpdateName"
                            Command="{Binding ClickCommand}"
                            />
                    <Button Content="-" Margin="2" Padding="10,2"
                            x:Name="TreeView_Button_Delete"
                            Command="{Binding ClickCommand}"
                            />
                    <!-- Добавьте свои инструменты для части A -->
                    
                </StackPanel>
            </Border>
            
            <!-- Основное содержимое части A -->
            <Border Grid.Row="1" Name="PartAContent" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <TreeView Grid.Row="0" Grid.Column="0"  AllowDrop="True" Background="Transparent"
                          Name="CategoryTreeView" 
                          ItemsSource="{Binding Items}" 
                          SelectedItemChanged="CategoriesTreeView_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="{x:Type TreeViewItem}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <EventSetter Event="DragEnter" Handler="TreeViewItem_DragEnter"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
                            <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove"/>
                            <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
                            <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Subcategories}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </Grid>
        
        <!-- ===== ЧАСТЬ B (70% ширины) ===== -->
        <Grid Grid.Column="1" Name="PartB">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Панель инструментов B (фиксированная) -->
                <RowDefinition Height="*"/>     <!-- Основное содержимое B (расширяемое) -->
            </Grid.RowDefinitions>
            
            <!-- Панель инструментов части B -->
            <Border Grid.Row="0" Name="PartBToolbar" Background="LightBlue" Height="40">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                    <Button x:Name="AddComponentButton"
                            Command="{Binding ClickCommand}"
                            Content="{Binding Label}" 
                            Margin="2" Padding="10,2"/>
                    <!-- Добавьте свои инструменты для части B -->
                    
                </StackPanel>
            </Border>
            
            <!-- Основное содержимое части B -->
            <Border Grid.Row="1" Name="PartBContent" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <DataGrid ItemsSource="{Binding Items}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              x:Name="MainDataGrid"
                              EnableRowVirtualization="False"
                              EnableColumnVirtualization="False"
                              MouseDoubleClick="DataGrid_OnMouseDoubleClick"
                              SelectedItem="{Binding SelectedItem}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <!-- Основные текстовые данные -->
                            <DataGridTextColumn Header="Наименование" IsReadOnly="True" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="250"/>
                            <DataGridTextColumn Header="Номенклатурный номер" IsReadOnly="True" Binding="{Binding NomenclatureNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180"/>
                            <DataGridTextColumn Header="Каталожный номер" IsReadOnly="True" Binding="{Binding CatalogNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180"/>
                            <DataGridTextColumn Header="Варианты маркировки" IsReadOnly="True" Binding="{Binding LabelingOptions, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180"/>
                            <DataGridTextColumn Header="Код элемента" IsReadOnly="True" Binding="{Binding CodeOfElement, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>

                        <!-- Справочные данные -->
                        <DataGridTextColumn Header="Условное обозначение" IsReadOnly="True" Binding="{Binding ConditionalDesignation.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180"/>
                        <DataGridTextColumn Header="Производитель" IsReadOnly="True" Binding="{Binding Manufacturer.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180"/>
                        <DataGridTextColumn Header="Единица измерения" IsReadOnly="True" Binding="{Binding MeasurementUnit.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="150"/>
                        <DataGridTextColumn Header="Типоразмер" IsReadOnly="True" Binding="{Binding TypeSize.Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>

                        <!-- Описательные данные -->
                        <DataGridTextColumn Header="QR код" IsReadOnly="True" Binding="{Binding QrCodeData, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="150"/>
                        <DataGridTextColumn Header="Описание" IsReadOnly="True" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="300"/>
                        <DataGridTextColumn Header="Комментарии" IsReadOnly="True" Binding="{Binding Comments, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="300"/>

                        <!-- Фото -->
                        <DataGridTemplateColumn Header="Фото" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImagePath}"
                                           Stretch="Uniform"
                                           MaxHeight="60"
                                           MaxWidth="60"
                                           Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Общие параметры -->
                        <DataGridTextColumn Header="Основной параметр" IsReadOnly="True" Binding="{Binding GpMain, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                        <DataGridTextColumn Header="1-й доп. параметр" IsReadOnly="True" Binding="{Binding Gp1, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                        <DataGridTextColumn Header="2-й доп. параметр" IsReadOnly="True" Binding="{Binding Gp2, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                        <DataGridTextColumn Header="3-й доп. параметр" IsReadOnly="True" Binding="{Binding Gp3, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                        <DataGridTextColumn Header="4-й доп. параметр" IsReadOnly="True" Binding="{Binding Gp4, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                        <DataGridTextColumn Header="5-й доп. параметр" IsReadOnly="True" Binding="{Binding Gp5, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="120"/>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="InfoDataGridContextMenuAddNewItemCommand"
                                      Header="Новое обозначение" Command="{Binding AddItemCommand}"></MenuItem>
                            <MenuItem x:Name="InfoDataGridContextMenuDeleteItemCommand"
                                      Header="Удалить" Command="{Binding DeleteCommand}"></MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
