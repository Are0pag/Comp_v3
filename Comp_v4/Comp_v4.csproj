  </ItemGroup>

  <ItemGroup>
    <Page Update="TableWindows\ConditionalDesignation\CondDesignTableWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <XamlRuntime>Wpf</XamlRuntime>
      <SubType>Designer</SubType>
