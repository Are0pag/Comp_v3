<Window x:Class="Comp_v3.Front.DataGrid.CondDesign.Window.CognDesignGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Comp_v3.Front.DataGrid.CondDesign.Window"
        mc:Ignorable="d"
        Title="MainW" Height="450" Width="800">
    <Grid>
        <DataGrid ItemsSource="{Binding Items}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  SelectionMode="Single" 
                  Name="InfoDataGrid" 
                  CellEditEnding="DataGrid_CellEditEnding"
                  BeginningEdit="InfoDataGrid_OnBeginningEdit"
                  PreviewKeyDown="InfoDataGrid_OnPreviewKeyDown"
                  SelectedItem="{Binding SelectedItem}">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Designation" Binding="{Binding Designation, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="*"/>
            </DataGrid.Columns>
            
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="InfoDataGridContextMenuAddNewItemCommand" 
                              Header="Новое обозначение" Command="{Binding AddItemCommand}"></MenuItem>
                    <MenuItem x:Name="InfoDataGridContextMenuDeleteItemCommand"
                              Header="Удалить" Command="{Binding DeleteItemCommand}"></MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            
        </DataGrid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10">
            <Button x:Name="AddNewItemButton" Content="Добавить" Command="{Binding AddItemCommand}" Margin="5"/>
            <Button x:Name="DeleteItemButton" Content="Удалить" Command="{Binding DeleteItemCommand}" Margin="5"/>
            <Button x:Name="SaveChangesButton" Content="Сохранить" Command="{Binding SaveChangesCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
